{
  "name": "trade-diary",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "한국 주식 매매 일지 · 분석 데스크톱/웹 앱 (개인용 로컬)",
  "author": "local",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:lan": "vite preview --host",
    "deploy": "npm run build && gh-pages -d dist -b gh-pages -m \"deploy\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "app:dev": "concurrently -k -n vite,electron -c blue,green \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "icon": "node scripts/make-icon.mjs",
    "app:portable": "node scripts/make-icon.mjs && npm run build && node scripts/portable.mjs",
    "app:install": "npm run app:portable && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install.ps1",
    "app:dir": "npm run build && electron-builder --dir",
    "app:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "gh-pages": "^6.3.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.45",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vitest": "^2.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.local.tradediary",
    "productName": "TradeDiary",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "매매일지"
    }
  }
}
